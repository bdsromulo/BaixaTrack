# Force CRLF on Windows-only scripts so CMD line continuation (`^`) works.
*.bat   text eol=crlf
*.ps1   text eol=crlf
*.iss   text eol=crlf

# Cross-platform sources stay LF.
*.py    text eol=lf
*.md    text eol=lf
*.yml   text eol=lf
*.yaml  text eol=lf

# Binary assets — never touch.
*.png   binary
*.ico   binary
